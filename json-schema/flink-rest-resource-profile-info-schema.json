{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-flink/refs/heads/main/json-schema/flink-rest-resource-profile-info-schema.json",
  "title": "ResourceProfileInfo",
  "description": "ResourceProfileInfo schema from Apache Flink REST API",
  "type": "object",
  "properties": {
    "cpuCores": {
      "type": "number",
      "format": "double"
    },
    "extendedResources": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "format": "double"
      }
    },
    "managedMemory": {
      "type": "integer",
      "format": "int32"
    },
    "networkMemory": {
      "type": "integer",
      "format": "int32"
    },
    "taskHeapMemory": {
      "type": "integer",
      "format": "int32"
    },
    "taskOffHeapMemory": {
      "type": "integer",
      "format": "int32"
    }
  }
}