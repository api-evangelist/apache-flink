{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-flink/refs/heads/main/json-schema/flink-rest-jar-file-info-schema.json",
  "title": "JarFileInfo",
  "description": "JarFileInfo schema from Apache Flink REST API",
  "type": "object",
  "properties": {
    "entry": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/JarEntryInfo"
      }
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "uploaded": {
      "type": "integer",
      "format": "int64"
    }
  }
}