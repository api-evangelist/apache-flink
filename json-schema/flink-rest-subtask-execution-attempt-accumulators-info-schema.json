{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-flink/refs/heads/main/json-schema/flink-rest-subtask-execution-attempt-accumulators-info-schema.json",
  "title": "SubtaskExecutionAttemptAccumulatorsInfo",
  "description": "SubtaskExecutionAttemptAccumulatorsInfo schema from Apache Flink REST API",
