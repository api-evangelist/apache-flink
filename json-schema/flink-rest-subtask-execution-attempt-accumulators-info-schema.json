      "type": "integer",
      "format": "int32"
    },
    "id": {
      "type": "string"
    },
    "subtask": {
      "type": "integer",
      "format": "int32"
    },
    "user-accumulators": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/UserAccumulator"
      }
    }
  }
}